# ---- TokenBoard web app ----

# Postgres connection (compose provides this automatically)
DATABASE_URL=postgres://tokenboard:devpw@localhost:5432/tokenboard

# Company scoping: only these email domains may sign in / ingest / appear on the leaderboard.
# Comma-separated. Empty = allow all (dev only).
ALLOWED_EMAIL_DOMAINS=

# HS256 secret used to sign/verify JWTs (device-token issuance, Auth Desk parity).
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=local-dev-secret-change-me-32bytes-min

# Secret required to trigger POST /api/leaderboard/refresh out-of-band (cron/manual).
LEADERBOARD_REFRESH_SECRET=local-dev-refresh-secret

# Run the in-process leaderboard refresh cron (every 5 min). Disable on multi-replica deploys.
LEADERBOARD_REFRESH_DISABLED=false

# ---- Auth (see plan: bypass now, wire Auth Desk later) ----
# Local dev (`pnpm dev`, NODE_ENV=development): true skips external SSO and uses a mock company
# user. On a production build this flag alone does nothing — bypass there also requires an
# explicit AUTH_BYPASS_ALLOW_IN_PROD=true (see infra/.env.example). Safe to keep true locally.
AUTH_BYPASS=true
# The mock user's email when AUTH_BYPASS=true (must be in an allowed domain to pass the company guard).
AUTH_BYPASS_EMAIL=dev@example.com

# Auth Desk SSO integration point (leave blank while AUTH_BYPASS=true; fill to wire real login).
NEXT_PUBLIC_AUTH_DESK_URL=
AUTH_DESK_API_URL=
NEXT_PUBLIC_AUTH_DESK_API_URL=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
DESK_SLUG=tokenboard
NEXT_PUBLIC_DESK_SLUG=tokenboard
DESK_NAME=TokenBoard
NEXT_PUBLIC_DESK_NAME=TokenBoard

LOGGER_LEVEL=info
