{
  "name": "tokenboard",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable AI token usage tracker with leaderboard and limits",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/api",
    "apps/cli",
    "apps/dashboard",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:dashboard": "npm --workspace apps/dashboard run dev",
    "migrate": "npm --workspace apps/api run migrate",
    "compose:up": "docker compose -f infra/docker-compose.yml up -d",
    "compose:down": "docker compose -f infra/docker-compose.yml down",
    "compose:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "typescript": "5.6.2",
    "@types/node": "20.14.10",
    "prettier": "3.3.3"
  }
}
