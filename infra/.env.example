# --------- Required ---------

# Public URL of the deployment (no trailing slash)
PUBLIC_URL=https://usage.example.com

# Postgres
DB_PASSWORD=change-me-to-a-long-random-password
# (Optional: override defaults)
DB_NAME=tokenboard
DB_USER=tokenboard

# JWT secret — at least 32 random bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-32-bytes-or-more

# Image tags
ORG=your-org
VERSION=0.1.0


# --------- Auth ---------

# OIDC (recommended for SSO). Leave empty to disable OIDC and only allow email/password.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Always set to PUBLIC_URL/api/v1/auth/oidc/callback
OIDC_REDIRECT_URI=

# Restrict signups to specific email domains (CSV). Leave empty to allow any email.
ALLOWED_EMAIL_DOMAINS=

# First user with this email will be promoted to admin on login. Optional.
BOOTSTRAP_ADMIN_EMAIL=

# Allow email/password signup. Set to "false" if you only want OIDC.
ALLOW_PASSWORD_SIGNUP=true


# --------- TLS ---------

# Mount your TLS cert + key into ./certs as fullchain.pem and privkey.pem.
# For local dev or behind another reverse proxy, set TLS_DISABLED=true.
TLS_DISABLED=false


# --------- Optional ---------

# Tighten the ingest endpoint by hashing device tokens at the proxy layer
# (defense in depth — server hashes them anyway).
INGEST_BEARER_HASH=true

# Slow query log threshold (ms) — emitted as warn-level structured logs.
SLOW_QUERY_MS=2000

# Max date range in days for read endpoints.
USAGE_MAX_DAYS=800

# Disable the leaderboard refresh cron (run it externally instead).
LEADERBOARD_REFRESH_DISABLED=false
