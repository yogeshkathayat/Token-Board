# ---- TokenBoard Docker Compose Environment ----

# Postgres password for the db service
POSTGRES_PASSWORD=devpw

# Company scoping: only these email domains may sign in / ingest / appear on the leaderboard.
# Comma-separated. Empty = allow all (dev only).
ALLOWED_EMAIL_DOMAINS=

# HS256 secret used to sign/verify JWTs (device-token issuance, Auth Desk parity).
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=local-dev-secret-change-me-32bytes-min

# NextAuth URL (external URL where the app is accessible)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000

# Secret required to trigger POST /api/leaderboard/refresh out-of-band (cron/manual)
LEADERBOARD_REFRESH_SECRET=local-dev-refresh-secret

# Run the in-process leaderboard refresh cron (every 5 min). Disable on multi-replica deploys.
LEADERBOARD_REFRESH_DISABLED=false

# ---- Auth (see plan: bypass now, wire Auth Desk later) ----
# This compose ships a WORKING INSECURE DEMO out of the box: auth is bypassed and every request
# is treated as AUTH_BYPASS_EMAIL. Fine to demo the full stack; NOT safe for real use.
#
# For a SECURE deploy: set AUTH_BYPASS=false (and remove AUTH_BYPASS_ALLOW_IN_PROD), then wire
# the Auth Desk SSO vars below. Because NODE_ENV=production, AUTH_BYPASS alone does nothing —
# enabling bypass on this production image REQUIRES the explicit acknowledgment flag too.
AUTH_BYPASS=true
AUTH_BYPASS_ALLOW_IN_PROD=true
# The mock user's email while bypass is active (must be in an allowed domain)
AUTH_BYPASS_EMAIL=dev@example.com

# Auth Desk SSO integration point (leave blank while AUTH_BYPASS=true)
# NEXT_PUBLIC_AUTH_DESK_URL=
# AUTH_DESK_API_URL=
# NEXT_PUBLIC_AUTH_DESK_API_URL=

# Application identity
DESK_SLUG=tokenboard
NEXT_PUBLIC_DESK_SLUG=tokenboard
DESK_NAME=TokenBoard
NEXT_PUBLIC_DESK_NAME=TokenBoard

# Log level
LOGGER_LEVEL=info

# Node environment
NODE_ENV=production
